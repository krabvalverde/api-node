generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@map("usuarios")
}

model Produto {
  id           Int    @id @default(autoincrement())
  codigoBarras String @unique @map("codigo_barras")
  descricao    String 
  unidade      String

  @@map("produtos")
}
